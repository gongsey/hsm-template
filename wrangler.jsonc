{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hsm-template",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-02",
  "kv_namespaces": [
    {
      "binding": "KV","id":  "82b312a401d74ad8b5b3793510075a07"
    }
  ],
  "env": {
    "production": {
      "name": "hsm",
      "kv_namespaces": [
        {
          "binding": "KV",
          "id": "82b312a401d74ad8b5b3793510075a07",
          "preview_id": "82b312a401d74ad8b5b3793510075a07"
        }
      ]
    },
    "staging": {
      "name": "hsm-staging",
      "kv_namespaces": [
        {
          "binding": "KV"
        }
      ]
    },
    "dev": {
      "name": "hsm-dev",
      "kv_namespaces": [
        {
          "binding": "KV"
        }
      ]
    }
  },
  "assets": {
    "directory": "./public"
  },
  "placement": {
    "mode": "smart"
  }
}
